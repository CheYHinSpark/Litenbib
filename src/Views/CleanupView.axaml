<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:Litenbib.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Litenbib.Views.CleanupView"
             x:DataType="vm:CleanupViewModel">
    <Design.DataContext>
        <vm:CleanupViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <TextBlock Margin="0 0 0 4"
                   Text="{CompiledBinding StatusMessage}"/>

        <Grid Grid.Row="1" ColumnDefinitions="300,*">
            <Border BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                    CornerRadius="8" Padding="8">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{DynamicResource Cleanup.Rules}"
                               FontWeight="SemiBold" Margin="0 0 0 8"/>
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{CompiledBinding RuleOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CleanupRuleOptionViewModel">
                                    <Border Margin="0 0 0 6" Padding="6" CornerRadius="4"
                                            Background="{DynamicResource InputBackground}">
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                            <CheckBox Grid.RowSpan="2" Margin="0 0 8 0"
                                                      VerticalAlignment="Top"
                                                      IsChecked="{CompiledBinding IsSelected}"/>
                                            <TextBlock Grid.Column="1" Margin="0"
                                                       Text="{CompiledBinding DisplayName}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0 2 0 0"
                                                       Text="{CompiledBinding Description}"
                                                       TextWrapping="Wrap"
                                                       Opacity="0.72"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorder}"
                    CornerRadius="8" Padding="8" Margin="8 0 0 0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{DynamicResource Cleanup.Preview}"
                               FontWeight="SemiBold" Margin="0 0 0 8"/>
                    <TextBlock Grid.Row="1" Margin="4"
                               Text="{DynamicResource Cleanup.NoChanges}"
                               IsVisible="{CompiledBinding HasChanges, Converter={x:Static BoolConverters.Not}}"
                               Opacity="0.65"/>
                    <ScrollViewer Grid.Row="1"
                                  IsVisible="{CompiledBinding HasChanges}">
                        <ItemsControl ItemsSource="{CompiledBinding PreviewChanges}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CleanupChangePreviewViewModel">
                                    <Border Margin="0 0 0 6" Padding="6" CornerRadius="4"
                                            Background="{DynamicResource InputBackground}">
                                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="128,*,28,*">
                                            <TextBlock Text="{CompiledBinding CitationKey}"
                                                       FontFamily="Consolas"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{CompiledBinding CitationKey}"/>
                                            <TextBlock Grid.Column="1" Text="{CompiledBinding FieldName}"
                                                       FontFamily="Consolas"
                                                       Opacity="0.75"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1"
                                                       Margin="0 4 0 0"
                                                       Text="{CompiledBinding OldValue}"
                                                       TextWrapping="Wrap"/>
                                            <Path Grid.Row="1" Grid.Column="2"
                                                  Data="{StaticResource RightPath}"
                                                  Stroke="{DynamicResource MainForeground}"
                                                  StrokeThickness="1"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="1" Grid.Column="3"
                                                       Margin="0 4 0 0"
                                                       Text="{CompiledBinding NewValue}"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
