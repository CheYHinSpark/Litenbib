<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="using:Litenbib.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Width="760" Height="760" CanResize="False"
        WindowStartupLocation="CenterScreen"
        x:Class="Litenbib.Views.AddEntryView"
        x:Name="AddEntryRoot"
        x:DataType="vm:AddEntryViewModel"
        Icon="/Assets/logo.ico"
        Title="Add Entry">
    <Window.Styles>
		<Style Selector="TextBox">
			<Setter Property="AcceptsReturn" Value="True"/>
			<Setter Property="AcceptsTab" Value="True"/>
			<Setter Property="TextWrapping" Value="Wrap"/>
			<Setter Property="FontFamily" Value="Consolas"/>
		</Style>
        <Style Selector="CheckBox">
            <Setter Property="Margin" Value="4 2"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </Window.Styles>
    
    <Design.DataContext>
        <vm:AddEntryViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,2*,2*,Auto" Margin="0 0 0 8">
		<StackPanel Margin="24 12 24 0" Spacing="4">
            <TextBlock Text="Add bibliography entries" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Resolve from DOI, arXiv, OpenReview, title, or URL. Then import only the candidates you want."
                       Opacity="0.7" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Name="MinButton" Click="TitleButton_Click" Classes="window">
				<Path Data="{StaticResource -Path}" StrokeThickness="1"
					  Stroke="{CompiledBinding $parent[Button].Foreground}"/>
			</Button>
			<Button Name="CloseButton" Click="TitleButton_Click" Classes="warning window">
				<Path Data="{StaticResource xPath}" StrokeThickness="1"
					  Stroke="{CompiledBinding $parent[Button].Foreground}"/>
			</Button>
        </StackPanel>
		
        <Grid Grid.Row="1" Margin="4" ColumnDefinitions="*,Auto">
            <TextBox Text="{Binding DoiText}" Margin="4 0"
					 Watermark="Input DOI / arXiv / OpenReview / title / URL, one per line."/>
			<Grid Grid.Column="1" >
				<TextBlock Text="Resolve Bib" Margin="8"/>
				<Button VerticalAlignment="Bottom" Content="Resolve"
						Margin="4 0"
						Command="{Binding ParseDoiCommand}"/>
			</Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="8 4" RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Text="Candidates" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Select All" Margin="4 0"
                        Command="{Binding SelectAllCandidatesCommand}"/>
                <Button Grid.Column="2" Content="Clear" Margin="4 0"
                        Command="{Binding ClearCandidateSelectionCommand}"/>
            </Grid>
            <Border Grid.Row="1" BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                    CornerRadius="8" Padding="4" Margin="0 4 0 0">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Candidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AddEntryCandidateViewModel">
                                <Border Margin="0 2" Padding="6" CornerRadius="6"
                                        Background="{DynamicResource InputBackground}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Command="{CompiledBinding $parent[Window].DataContext.RefreshSelectedBibtexCommand}"
                                                  CommandParameter="{Binding .}"/>
                                        <StackPanel Grid.Column="1" Margin="8 0 0 0">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding CitationKey}" IsVisible="{Binding CitationKey, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock>
                                                <Run Text="Source: "/>
                                                <Run Text="{Binding Source}"/>
                                                <Run Text=" | Query: "/>
                                                <Run Text="{Binding Query}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <TextBox Grid.Row="3" Margin="8 4"
				 Watermark="Selected BibTeX entries to import. You can still edit manually."
				 Text="{Binding BibtexText}"/>
		<TextBlock Grid.Row="4" Margin="8 0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					Text="{Binding HintText}"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal"
					Margin="0 4 8 8"
                    HorizontalAlignment="Right">
			<Button Content="Cancel" Width="64" Click="CancelButton_Click"/>
			<Button Content="Add" Width="64" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
