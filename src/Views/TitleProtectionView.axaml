<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:Litenbib.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Litenbib.Views.TitleProtectionView"
             x:DataType="vm:TitleProtectionViewModel">
    <Design.DataContext>
        <vm:TitleProtectionViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock VerticalAlignment="Center"
                   Text="{CompiledBinding StatusMessage}"/>
        
        <StackPanel Grid.Row="1" Margin="0 4" Spacing="8"
                    HorizontalAlignment="Left" Orientation="Horizontal">
            <CheckBox Grid.Column="2"
                      VerticalAlignment="Center"
                      IsChecked="{CompiledBinding ProtectTerms, Mode=TwoWay}"/>
            <TextBlock Text="{DynamicResource TitleProtection.ProtectTerms}"/>
        </StackPanel>

         <Button Grid.Row="1" Height="28" Margin="0" Padding="4 2"
                 HorizontalAlignment="Right" VerticalAlignment="Center"
                 Command="{CompiledBinding OpenTermsFileCommand}"
                 ToolTip.Tip="{DynamicResource TitleProtection.Tooltip.EditTerms}">
             <Grid ColumnDefinitions="20,*">
                 <Path Data="{StaticResource FilePath}"
                       StrokeThickness="1"
                       Stroke="{CompiledBinding $parent[Button].Foreground}"/>
                 <TextBlock Grid.Column="1"
                            Margin="6 0 0 0"
                            Text="{DynamicResource TitleProtection.EditTerms}"/>
            </Grid>
        </Button>

        <StackPanel Grid.Row="2" Margin="0 4" Spacing="8"
                    HorizontalAlignment="Left" Orientation="Horizontal">
            <CheckBox Grid.Column="2"
                      VerticalAlignment="Center"
                      IsChecked="{CompiledBinding ProtectTitleCase, Mode=TwoWay}"/>
            <TextBlock Text="{DynamicResource TitleProtection.ProtectTitleCase}"/>
        </StackPanel>

        <Border Grid.Row="3" BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                CornerRadius="8" Padding="4">
            <ScrollViewer Padding="4 4 4 -8">
                <ItemsControl ItemsSource="{CompiledBinding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TitleProtectionItemViewModel">
                            <Border Margin="0 2" Padding="6" CornerRadius="4"
                                    Background="{DynamicResource InputBackground}">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="130,*">
                                    <TextBlock Text="{CompiledBinding CitationKey}" Margin="2"
                                               FontWeight="SemiBold" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{CompiledBinding CitationKey}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Margin="12 0 2 0"
                                               Text="{DynamicResource Bibtex.Column.Title}"
                                               Opacity="0.72"/>

                                    <TextBlock Grid.Row="1" Text="Title" FontFamily="Consolas"
                                               IsVisible="{CompiledBinding HasTitle}"
                                               Opacity="0.8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto,*"
                                          IsVisible="{CompiledBinding HasTitle}">
                                        <TextBox Grid.Column="0" Margin="4 0" IsReadOnly="True"
                                                 Text="{CompiledBinding OriginalTitle}"
                                                 TextWrapping="Wrap"
                                                 BorderBrush="Transparent"
                                                 BorderThickness="0"
                                                 Background="Transparent"/>
                                        <Button Grid.Column="1" Width="24" Height="24" Classes="in_section"
                                                VerticalAlignment="Center"
                                                ToolTip.Tip="{DynamicResource Common.Reset}"
                                                Command="{CompiledBinding ResetSuggestionCommand}">
                                            <Path Data="{StaticResource ResetPath}"
                                                  Fill="{CompiledBinding $parent[Button].Foreground}"/>
                                        </Button>
                                        <TextBox Grid.Column="2" Margin="4 0"
                                                 Text="{CompiledBinding SuggestedTitle, Mode=TwoWay}"
                                                 TextWrapping="Wrap"/>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="12 0"
                                               Text="{DynamicResource TitleProtection.NoTitle}"
                                               IsVisible="{CompiledBinding HasTitle, Converter={x:Static BoolConverters.Not}}"
                                               Opacity="0.65"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
