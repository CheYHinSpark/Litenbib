<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <SolidColorBrush x:Key="DataGridGridLinesBrush" Color="Transparent"/>
	
    <ControlTheme x:Key="{x:Type DataGridColumnHeader}" TargetType="DataGridColumnHeader">
		<Setter Property="Background" Value="{DynamicResource BarBackground}"/>
		<Setter Property="Foreground" Value="{DynamicResource MainForeground}"/>
        <Setter Property="Padding" Value="0 8"/>
		<Setter Property="AreSeparatorsVisible" Value="False"/>
		<Setter Property="SeparatorBrush" Value="{DynamicResource BarBorder}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BarBorder}"/>
        <Setter Property="BorderThickness" Value="0 1"/>
		<Setter Property="Template">
            <ControlTemplate>
                <Grid Name="PART_ColumnHeaderRoot" ColumnDefinitions="*,1">
					<Border Name="PART_Border"
							Grid.ColumnSpan="2"
							Background="{TemplateBinding Background}"
							Opacity="0.95"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}"/>
                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    <Border Name="PART_SortBorder" Background="{DynamicResource ThemeBorder}"
                            HorizontalAlignment="Stretch" Margin="8 1" Height="2" CornerRadius="1"/>
                    <Rectangle Name="VerticalSeparator" Grid.Column="1" Width="1"
                               VerticalAlignment="Stretch" Fill="{TemplateBinding SeparatorBrush}"
                               IsVisible="{TemplateBinding AreSeparatorsVisible}"/>
                </Grid>
            </ControlTemplate>
        </Setter>

		<Style Selector="^:nth-child(1)">
			<Setter Property="CornerRadius" Value="0 0 0 8"/>
            <Setter Property="BorderThickness" Value="1 1 0 1"/>
		</Style>

		<Style Selector="^:nth-last-child(1)">
			<Setter Property="CornerRadius" Value="0 0 8 0"/>
            <Setter Property="BorderThickness" Value="0 1 1 1"/>
		</Style>

		<Style Selector="^:sortascending /template/ Border#PART_SortBorder">
            <Setter Property="IsVisible" Value="True"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
		</Style>

		<Style Selector="^:sortdescending /template/ Border#PART_SortBorder">
            <Setter Property="IsVisible" Value="True"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
		</Style>

        <Style Selector="^:not(:sortascending):not(:sortdescending) /template/ Border#PART_SortBorder">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type DataGridCell}" TargetType="DataGridCell">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <ControlTemplate>
				<Grid>
					<Border x:Name="CellBorder"
                            Background="Transparent"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
							Opacity="1">
					</Border>
					<ContentPresenter Margin="{TemplateBinding Padding}"
									  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
									  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
									  Content="{TemplateBinding Content}"
									  ContentTemplate="{TemplateBinding ContentTemplate}"
									  Foreground="{TemplateBinding Foreground}" />
				</Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type DataGridRow}" TargetType="DataGridRow">
        <Setter Property="Template">
            <ControlTemplate>
                <DataGridFrozenGrid Name="PART_Root"
                                    ColumnDefinitions="Auto,*"
									Background="{TemplateBinding Background}"
                                    RowDefinitions="*,Auto">
                    <Border Name="BackgroundBorder" MinHeight="32" CornerRadius="8"
                            Margin="0 2" Grid.RowSpan="2" Grid.ColumnSpan="2"
                            Background="{DynamicResource ThemeHighlight}"
                            BorderBrush="{DynamicResource ThemeHighlight}"
                            BorderThickness="1" Opacity="0">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                    <DataGridRowHeader Name="PART_RowHeader"
                                       Grid.RowSpan="2"
                                       DataGridFrozenGrid.IsFrozen="True" />
                    <DataGridCellsPresenter Name="PART_CellsPresenter"
                                            Grid.Column="1"
                                            DataGridFrozenGrid.IsFrozen="True" />
                    <DataGridDetailsPresenter Name="PART_DetailsPresenter"
                                              Grid.Row="1"
                                              Grid.Column="1"
                                              Background="{DynamicResource DataGridDetailsPresenterBackgroundBrush}" />
                </DataGridFrozenGrid>
            </ControlTemplate>
        </Setter>

		<Style Selector="^:pointerover /template/ Border#BackgroundBorder">
            <Setter Property="Opacity" Value="0.8"/>
		</Style>

        <Style Selector="^:selected /template/ Border#BackgroundBorder">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
