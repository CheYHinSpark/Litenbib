<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="MainBackgroundColor">#E1EAF3</Color>
    <Color x:Key="TabBackgroundColor">#F0F3F6</Color>
    <Color x:Key="PanelBackgroundColor">#F3F9FF</Color>
    <Color x:Key="BarBackgroundColor">#E7F3FF</Color>
    <Color x:Key="InputBackgroundColor">#F9FCFF</Color>
    <Color x:Key="ThemeBackgroundColor">#9CCCFC</Color>
    <Color x:Key="TextSelectionHighlightColor">#9CE4C6</Color>
    
    <Color x:Key="MainHighlightColor">#CFDBE7</Color>
    <Color x:Key="ThemeHighlightColor">#C9E4FF</Color>
    <Color x:Key="WarningHighlightColor">#D54836</Color>

    <Color x:Key="DisabledForegroundColor">#72787E</Color>
    <Color x:Key="MainForegroundColor">#12181E</Color>

    <Color x:Key="MainBorderColor">#B1D5F9</Color>
    <Color x:Key="BarBorderColor">#6699CC</Color>
    <Color x:Key="ThemeBorderColor">#0369CF</Color>

    <Color x:Key="BibtexEntryTypeColor">#006F99</Color>
    <Color x:Key="BibtexCitationKeyColor">#B16027</Color>
    <Color x:Key="BibtexFieldColor">#8D216F</Color>
    <Color x:Key="BibtexValueColor">#457B39</Color>
    <Color x:Key="BibtexPunctuationColor">#7B8187</Color>
    <Color x:Key="BibtexCommentColor">#5D6369</Color>
</ResourceDictionary>
