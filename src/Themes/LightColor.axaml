<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="DisabledForegroundColor">#7A8496</Color>
    <Color x:Key="InputBackgroundColor">#F4F7FA</Color>
    <Color x:Key="HighlightBackgroundColor">#DFE9F7</Color>
    <Color x:Key="HighlightBorderColor">#7B93BF</Color>
    <Color x:Key="HighlightForegroundColor">#000000</Color>
    <Color x:Key="MainBackgroundColor">#EEF2F7</Color>
    <Color x:Key="MainBorderColor">#D7DFEA</Color>
	<Color x:Key="MainForegroundColor">#222222</Color>
	<Color x:Key="TextSelectionHighlightColor">#BAFEDC</Color>

	<Color x:Key="TabBackgroundColor">#D1E0F4</Color>
    <Color x:Key="ThemeBackgroundColor">#DCEBFF</Color>
    <Color x:Key="ThemeBorderColor">#4D89D8</Color>
    <Color x:Key="ThemeHighlightColor">#C1D0E4</Color>
    <Color x:Key="WarningBackgroundColor">#F54B4B</Color>
</ResourceDictionary>
