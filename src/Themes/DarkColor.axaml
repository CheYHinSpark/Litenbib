<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="MainBackgroundColor">#2C2F3B</Color>
    <Color x:Key="TabBackgroundColor">#1E2732</Color>
    <Color x:Key="PanelBackgroundColor">#3C4654</Color>
    <Color x:Key="BarBackgroundColor">#12264F</Color>
    <Color x:Key="InputBackgroundColor">#151D29</Color>
    <Color x:Key="ThemeBackgroundColor">#4A4B9D</Color>
    <Color x:Key="TextSelectionHighlightColor">#206864</Color>
    
    <Color x:Key="MainHighlightColor">#45465E</Color>
    <Color x:Key="ThemeHighlightColor">#1A2847</Color>
    <Color x:Key="WarningHighlightColor">#B93A26</Color>
    
    <Color x:Key="DisabledForegroundColor">#9AA7B1</Color>
    <Color x:Key="MainForegroundColor">#EBEEE8</Color>
    
    <Color x:Key="MainBorderColor">#547689</Color>
    <Color x:Key="BarBorderColor">#446A37</Color>
    <Color x:Key="ThemeBorderColor">#615EA8</Color>

    <Color x:Key="BibtexEntryTypeColor">#A3BBDB</Color>
    <Color x:Key="BibtexCitationKeyColor">#FFEE6F</Color>
    <Color x:Key="BibtexFieldColor">#BBA1CB</Color>
    <Color x:Key="BibtexValueColor">#B1D5C8</Color>
    <Color x:Key="BibtexPunctuationColor">#BDCBD2</Color>
    <Color x:Key="BibtexCommentColor">#D4DDE1</Color>
</ResourceDictionary>
